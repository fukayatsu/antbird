# Generated REST API methods file - DO NOT EDIT!
# <%= engine_name %> version: <%= version %>

module Antbird
  module RestApi
    module RestApi<%= engine_name_prefix.delete_suffix('_').capitalize %>V<%= class_version %>
      def common_params
        @common_params ||= <%= api_spec['_common.json'] || {} %>
      end
<% api_spec.each do |file_name, file_content| %>
<%  next if file_name == '_common.json' %>
<%  file_content.each do |api_name, api_spec| %>
<%    path_params = api_spec['url']['paths'].flat_map { |path|
        if path.is_a?(Hash) && path['parts']
          path['parts'].keys.map(&:to_sym)
        else
          p = path.is_a?(Hash) ? path['path'] : path
          p.scan(/\{([a-z_\-]+)\}/).flatten.map(&:to_sym)
        end
      }.uniq
      minimal_paths = api_spec['url']['paths'].map { |path|
        if path.is_a?(Hash)
          h = { 'path' => path['path'], 'methods' => path['methods'] }
          h['deprecated'] = true if path['deprecated']
          h
        else
          path
        end
      }
      minimal_spec = { 'url' => { 'paths' => minimal_paths } }
      minimal_spec['methods'] = api_spec['methods'] if api_spec['methods']
      minimal_spec['body'] = { 'required' => true } if api_spec.dig('body', 'required')
      if api_spec['params']
        minimal_spec['params'] = {}
        api_spec['params'].each do |pname, pdefn|
          info = { 'type' => pdefn['type'] }
          info['required'] = true if pdefn['required']
          minimal_spec['params'][pname] = info
        end
      end
%>

      # <%= api_name %> <%= api_spec['methods'] %>
      # <%= api_spec['documentation'] %>
      def <%= api_name.tr('.', '_') %>(params = {})
        api_name = '<%= api_name %>'
        api_spec = @api_specs[api_name] ||= <%= minimal_spec.inspect %>
        request(api_name, api_spec, params, <%= path_params.inspect %>)
      end
<%    if api_spec['methods'] == ['HEAD'] || api_spec['url']['paths'].map{ |path| path.is_a?(Hash) ? path['methods'] : false }.all? { |methods| methods == ['HEAD'] } %>
      alias :<%= api_name.tr('.', '_') %>? :<%= api_name.tr('.', '_') %>
<%    end %>
<%  end # file_content.each %>
<% end # api_spec.each %>
    end
  end
end
